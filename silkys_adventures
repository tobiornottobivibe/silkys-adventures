const SOLID = new Set([0,1,6]);
// ── CAMERA ───────────────────────────────────────────────────
const cam = { x:0, y:0 };
function updateCamera(px, py) {
cam.x = Math.max(0, Math.min(px - 320, MAP_COLSTILE_SIZE - 640));
cam.y = Math.max(0, Math.min(py - 240, MAP_ROWSTILE_SIZE - 480));
}
// ── PLAYER ───────────────────────────────────────────────────
const player = {
x: 10TILE_SIZE + 16, y: 7TILE_SIZE + 16,
w: 28, h: 28,
speed: 2,
dir: 0, // 0=down 1=up 2=left 3=right
moving: false,
stars: parseInt(localStorage.getItem('silkyStars')||'0'),
hearts: 3
};
function playerTileCollide(nx, ny) {
const hw = 10, hh = 10;
const corners = [
[nx-hw, ny-hh], [nx+hw, ny-hh],
[nx-hw, ny+hh], [nx+hw, ny+hh]
];
for (const [cx,cy] of corners) {
const tc = Math.floor(cx/TILE_SIZE);
const tr = Math.floor(cy/TILE_SIZE);
if (tr<0||tr>=MAP_ROWS||tc<0||tc>=MAP_COLS) return true;
if (SOLID.has(mapData[tr][tc])) return true;
}
return false;
}
function movePlayer() {
let dx=0, dy=0;
if (keys['ArrowUp'] || keys['KeyW']) { dy=-1; player.dir=1; }
if (keys['ArrowDown'] || keys['KeyS']) { dy= 1; player.dir=0; }
if (keys['ArrowLeft'] || keys['KeyA']) { dx=-1; player.dir=2; }
if (keys['ArrowRight'] || keys['KeyD']) { dx= 1; player.dir=3; }
player.moving = (dx!==0||dy!==0);
if (dx!==0&&dy!==0) { dx*=0.707; dy*=0.707; }
const spd = player.speed;
const nx = player.x + dxspd;
const ny = player.y + dyspd;
if (!playerTileCollide(nx, player.y)) player.x = nx;
if (!playerTileCollide(player.x, ny)) player.y = ny;
}
// ── NPCs ─────────────────────────────────────────────────────
const npcs = [
{
