ctx.beginPath(); ctx.ellipse(cl.x+22,cl.y+5,cl.w/3,cl.h/3,0,0,Math.PI*2); ctx.fill();
});
// seagulls (fixed to screen)
seagulls.forEach(sg => {
ctx.strokeStyle='#555'; ctx.lineWidth=1.5;
ctx.beginPath();
ctx.moveTo(sg.x-8,sg.y); ctx.quadraticCurveTo(sg.x-4,sg.y-5,sg.x,sg.y);
ctx.quadraticCurveTo(sg.x+4,sg.y-5,sg.x+8,sg.y);
ctx.stroke();
});
}
// ── DRAWING: SILKY ────────────────────────────────────────────
function drawSilky(sx, sy) {
const bob = player.moving ? Math.sin(frame*0.18)2 : Math.sin(frame0.06)*1;
const x = sx; const y = sy + bob;
// shadow
