ctx.fillStyle='#1a1a1a';
ctx.beginPath(); ctx.arc(x-4+eyeOff,y-10,2.5,0,Math.PI2); ctx.fill();
ctx.beginPath(); ctx.arc(x+4+eyeOff,y-10,2.5,0,Math.PI2); ctx.fill();
ctx.fillStyle='white';
ctx.beginPath(); ctx.arc(x-3+eyeOff,y-11,1,0,Math.PI2); ctx.fill();
ctx.beginPath(); ctx.arc(x+5+eyeOff,y-11,1,0,Math.PI2); ctx.fill();
