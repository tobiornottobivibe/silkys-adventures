ctx.fillRect(sx+0,sy+10,8,14);
// body / shirt
ctx.fillStyle=npc.shirt;
ctx.fillRect(sx-10,sy-8+bob,20,20);
// arms
ctx.fillStyle=npc.shirt;
ctx.fillRect(sx-16,sy-6+bob,7,12);
ctx.fillRect(sx+10,sy-6+bob,7,12);
