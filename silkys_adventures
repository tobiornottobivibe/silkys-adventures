ctx.moveTo(x-6,y+12); ctx.lineTo(x,y+18); ctx.lineTo(x+6,y+12);
ctx.closePath(); ctx.fill();
ctx.fillStyle='#4A90D9';
ctx.beginPath();
ctx.moveTo(x-4,y+12); ctx.lineTo(x,y+16); ctx.lineTo(x+4,y+12);
ctx.closePath(); ctx.fill();
