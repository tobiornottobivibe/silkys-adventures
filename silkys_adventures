ctx.fillStyle='#FFFFFF';
ctx.beginPath(); ctx.ellipse(x-14,y+4,5,3,-0.4,0,Math.PI2); ctx.fill();
ctx.beginPath(); ctx.ellipse(x+14,y+4,5,3,0.4,0,Math.PI2); ctx.fill();
// head
