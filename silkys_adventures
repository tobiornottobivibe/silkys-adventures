];
// ── DIALOGUE STATE ────────────────────────────────────────────
let activeNPC = null;
let dlgPhase = 0; // 0=greeting 1=tip 2=quiz
let quizIndex = 0;
let quizResult = null; // null | 'correct' | 'wrong'
let quizExp = '';
let quizFlash = 0;
let quizEarned = 0;
let dlgPage = 0; // for multi-page greeting/tip
// ── DECORATIONS ───────────────────────────────────────────────
const seagulls = [
{x:50, y:60, spd:0.4},
{x:300, y:40, spd:0.3},
{x:500, y:80, spd:0.5}
];
const clouds = [
{x:80, y:30, w:90, h:35, spd:0.15},
{x:350, y:20, w:110,h:40, spd:0.10},
{x:550, y:50, w:80, h:30, spd:0.20}
];
let lighthouseAngle = 0;
let waterPulse = 0;
// ── QUIZ BUTTON RECTS (screen coords) ────────────────────────
const qBtns = [
{x:60, y:390, w:160, h:36},
{x:240, y:390, w:160, h:36},
{x:420, y:390, w:160, h:36}
];
let hoveredBtn = -1;
canvas.addEventListener('mousemove', e => {
if (state !== STATE.QUIZ) { hoveredBtn=-1; return; }
const r = canvas.getBoundingClientRect();
const mx = e.clientX - r.left;
const my = e.clientY - r.top;
hoveredBtn = -1;
qBtns.forEach((b,i) => {
if (mx>=b.x&&mx<=b.x+b.w&&my>=b.y&&my<=b.y+b.h) hoveredBtn=i;
});
});
canvas.addEventListener('click', e => {
const r = canvas.getBoundingClientRect();
const mx = e.clientX - r.left;
const my = e.clientY - r.top;
if (state === STATE.MENU) { startGame(); return; }
if (state === STATE.WIN) { resetGame(); return; }
if (state === STATE.DIALOGUE) {
// click anywhere advances dialogue
advanceDialogue();
return;
}
if (state === STATE.QUIZ && quizResult === null) {
qBtns.forEach((b,i) => {
if (mx>=b.x&&mx<=b.x+b.w&&my>=b.y&&my<=b.y+b.h) selectAnswer(i);
});
} else if (state === STATE.QUIZ && quizResult !== null) {
nextQuizStep();
}
});
// ── HELPERS ───────────────────────────────────────────────────
function wrapText(ctx, text, x, y, maxW, lineH) {
const lines = text.split('\n');
lines.forEach(line => {
const words = line.split(' ');
let cur = '';
words.forEach(w => {
const test = cur ? cur+' '+w : w;
if (ctx.measureText(test).width > maxW && cur) {
ctx.fillText(cur, x, y); y += lineH; cur = w;
} else cur = test;
});
ctx.fillText(cur, x, y); y += lineH;
});
return y;
}
// ── DRAWING: TILES ────────────────────────────────────────────
function drawTile(id, px, py) {
const pulse = Math.sin(waterPulse)0.5+0.5;
switch(id) {
case 0: // deep water
ctx.fillStyle = rgb(${Math.round(26+pulse*20)},${Math.round(111+pulse*20)},${Math.round(168+pulse*10)});
ctx.fillRect(px,py,TILE_SIZE,TILE_SIZE);
if ((Math.floor(px/TILE_SIZE)+Math.floor(py/TILE_SIZE))%3===0) {
ctx.fillStyle='rgba(255,255,255,0.15)';
ctx.fillRect(px+4,py+14,12,2); ctx.fillRect(px+18,py+20,8,2);
}
break;
case 1: // shallow water
ctx.fillStyle='#5BA4CF';
ctx.fillRect(px,py,TILE_SIZE,TILE_SIZE);
ctx.fillStyle='rgba(255,255,255,0.4)';
for(let i=0;i<3;i++) ctx.fillRect(px+4+i9,py+12+i4,6,2);
break;
case 2: // wet sand
ctx.fillStyle='#C8A96E';
ctx.fillRect(px,py,TILE_SIZE,TILE_SIZE);
ctx.fillStyle='rgba(255,255,255,0.2)';
ctx.fillRect(px,py,TILE_SIZE,4);
break;
case 3: // sand
ctx.fillStyle='#F4D03F';
ctx.fillRect(px,py,TILE_SIZE,TILE_SIZE);
ctx.fillStyle='rgba(200,160,80,0.3)';
ctx.fillRect(px+8,py+8,4,4); ctx.fillRect(px+20,py+18,3,3);
break;
case 4: // promenade
ctx.fillStyle='#95A5A6';
ctx.fillRect(px,py,TILE_SIZE,TILE_SIZE);
ctx.fillStyle='rgba(255,255,255,0.1)';
ctx.fillRect(px,py,TILE_SIZE,2);
break;
case 5: // grass
ctx.fillStyle='#52B788';
ctx.fillRect(px,py,TILE_SIZE,TILE_SIZE);
break;
case 6: // rock
ctx.fillStyle='#7F8C8D';
ctx.fillRect(px,py,TILE_SIZE,TILE_SIZE);
ctx.fillStyle='#6C7A7D';
ctx.fillRect(px+4,py+4,10,8); ctx.fillRect(px+16,py+10,10,8);
break;
case 7: // flower
ctx.fillStyle='#52B788';
ctx.fillRect(px,py,TILE_SIZE,TILE_SIZE);
ctx.fillStyle='#FF6B9D';
ctx.beginPath(); ctx.arc(px+16,py+16,4,0,Math.PI2); ctx.fill();
ctx.fillStyle='#FFE066';
ctx.beginPath(); ctx.arc(px+16,py+16,2,0,Math.PI*2); ctx.fill();
break;
}
}
function drawMap() {
for (let r=0;r<MAP_ROWS;r++) {
for (let c=0;c<MAP_COLS;c++) {
const px = cTILE_SIZE - cam.x;
const py = rTILE_SIZE - cam.y;
if (px>-TILE_SIZE&&px<640&&py>-TILE_SIZE&&py<480)
drawTile(mapData[r][c], px, py);
}
}
}
// ── DRAWING: LIGHTHOUSE ───────────────────────────────────────
function drawLighthouse() {
const lx = 18TILE_SIZE - cam.x;
const ly = 9TILE_SIZE - cam.y;
// base
ctx.fillStyle='#BDC3C7';
ctx.fillRect(lx+8,ly+64,16,16);
// tower
ctx.fillStyle='#ECF0F1';
ctx.fillRect(lx+10,ly+10,12,56);
// stripes
ctx.fillStyle='#E74C3C';
ctx.fillRect(lx+10,ly+20,12,8);
ctx.fillRect(lx+10,ly+40,12,8);
// top
ctx.fillStyle='#E74C3C';
ctx.beginPath(); ctx.arc(lx+16,ly+10,8,0,Math.PI*2); ctx.fill();
// beam
ctx.save();
ctx.translate(lx+16, ly+10);
ctx.rotate(lighthouseAngle);
const grad = ctx.createLinearGradient(0,0,80,0);
grad.addColorStop(0,'rgba(255,255,200,0.6)');
grad.addColorStop(1,'rgba(255,255,200,0)');
ctx.fillStyle=grad;
ctx.beginPath();
ctx.moveTo(0,0);
ctx.lineTo(80,-12);
ctx.lineTo(80,12);
ctx.closePath();
ctx.fill();
ctx.restore();
}
// ── DRAWING: DECORATIONS ──────────────────────────────────────
function drawDecorations() {
