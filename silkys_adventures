// hair
ctx.fillStyle=npc.hair;
ctx.beginPath(); ctx.arc(sx,sy-22+bob,9,Math.PI,0); ctx.fill();
ctx.fillRect(sx-9,sy-22+bob,18,5);
// eyes
ctx.fillStyle='#1a1a1a';
ctx.beginPath(); ctx.arc(sx-4,sy-17+bob,2,0,Math.PI2); ctx.fill();
ctx.beginPath(); ctx.arc(sx+4,sy-17+bob,2,0,Math.PI2); ctx.fill();
// smile
ctx.strokeStyle='#8B4513'; ctx.lineWidth=1.5;
ctx.beginPath();
ctx.arc(sx,sy-12+bob,4,0.2,Math.PI-0.2);
ctx.stroke();
// special accessories
if (npc.id==='justin') {
// camera
ctx.fillStyle='#333';
ctx.fillRect(sx+10,sy-4+bob,10,7);
ctx.fillStyle='#555';
ctx.beginPath(); ctx.arc(sx+15,sy-1+bob,3,0,Math.PI*2); ctx.fill();
}
if (npc.id==='abby') {
// music notes
ctx.fillStyle='#FF69B4';
ctx.font='12px serif';
ctx.fillText('♪',sx-18,sy-20+bob);
ctx.fillText('♫',sx+12,sy-24+bob);
}
if (npc.id==='leo') {
// dance pose - one arm up
ctx.fillStyle=npc.shirt;
ctx.fillRect(sx+10,sy-18+bob,7,12);
}
if (npc.id==='maya') {
// small sail shape
ctx.fillStyle='white';
ctx.beginPath();
ctx.moveTo(sx-18,sy-4+bob);
ctx.lineTo(sx-18,sy-18+bob);
ctx.lineTo(sx-10,sy-4+bob);
ctx.closePath(); ctx.fill();
}
// "done" checkmark
if (npc.done) {
ctx.fillStyle='#2ECC71';
ctx.font='bold 14px sans-serif';
ctx.fillText('✓',sx-5,sy-32+bob);
}
// proximity hint
const dist = Math.hypot(player.x-npc.x, player.y-npc.y);
if (dist<52 && state===STATE.PLAYING) {
ctx.fillStyle='rgba(0,0,0,0.7)';
ctx.beginPath();
const hw=60, hh=18;
roundRect(ctx, sx-hw/2, sy-52+bob, hw, hh, 6);
ctx.fill();
ctx.fillStyle='#FFE066';
ctx.font='11px sans-serif';
ctx.textAlign='center';
ctx.fillText('Press E to talk', sx, sy-39+bob);
ctx.textAlign='left';
}
}
function roundRect(ctx,x,y,w,h,r){
ctx.beginPath();
ctx.moveTo(x+r,y);
ctx.lineTo(x+w-r,y); ctx.quadraticCurveTo(x+w,y,x+w,y+r);
ctx.lineTo(x+w,y+h-r); ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
ctx.lineTo(x+r,y+h); ctx.quadraticCurveTo(x,y+h,x,y+h-r);
ctx.lineTo(x,y+r); ctx.quadraticCurveTo(x,y,x+r,y);
ctx.closePath();
}
// ── DRAWING: HUD ──────────────────────────────────────────────
function drawHUD() {
// stars
ctx.fillStyle='#FFE066';
ctx.font='bold 20px sans-serif';
ctx.fillText('⭐ '+player.stars, 12, 30);
// hearts
ctx.textAlign='right';
ctx.fillStyle='#E74C3C';
ctx.fillText('❤️'.repeat(player.hearts), 628, 30);
ctx.textAlign='left';
// location
ctx.fillStyle='rgba(0,0,0,0.5)';
roundRect(ctx,8,448,160,24,6); ctx.fill();
ctx.fillStyle='white'; ctx.font='13px sans-serif';
ctx.fillText('📍 Plymouth Beach', 14, 464);
}
// ── DRAWING: DIALOGUE BOX ─────────────────────────────────────
function drawDialogueBox() {
if (!activeNPC) return;
const npc = activeNPC;
// box
ctx.fillStyle='rgba(0,0,0,0.88)';
roundRect(ctx,10,330,620,140,10); ctx.fill();
ctx.strokeStyle=npc.shirt; ctx.lineWidth=2;
roundRect(ctx,10,330,620,140,10); ctx.stroke();
// portrait circle
ctx.fillStyle=npc.shirt;
ctx.beginPath(); ctx.arc(55,370,30,0,Math.PI2); ctx.fill();
ctx.fillStyle='#FDBCB4';
ctx.beginPath(); ctx.arc(55,362,14,0,Math.PI2); ctx.fill();
ctx.fillStyle=npc.hair;
ctx.beginPath(); ctx.arc(55,356,12,Math.PI,0); ctx.fill();
ctx.fillStyle='#1a1a1a';
ctx.beginPath(); ctx.arc(51,363,2,0,Math.PI2); ctx.fill();
ctx.beginPath(); ctx.arc(59,363,2,0,Math.PI2); ctx.fill();
// name
ctx.fillStyle=npc.shirt;
ctx.font='bold 15px sans-serif';
ctx.fillText(npc.name, 95, 352);
// text
ctx.fillStyle='white'; ctx.font='14px sans-serif';
const text = dlgPhase===0 ? npc.greeting : npc.grammarTip;
wrapText(ctx, text, 95, 370, 520, 20);
// continue hint
blinkTimer++;
if (Math.floor(blinkTimer/30)%2===0) {
ctx.fillStyle='#87CEEB'; ctx.font='12px sans-serif';
ctx.textAlign='right';
ctx.fillText('Press E to continue ▶', 625, 462);
ctx.textAlign='left';
}
}
// ── DRAWING: QUIZ ─────────────────────────────────────────────
function drawQuiz() {
if (!activeNPC) return;
const npc = activeNPC;
const q = npc.questions[quizIndex];
// box
ctx.fillStyle='rgba(0,0,0,0.92)';
roundRect(ctx,10,300,620,170,10); ctx.fill();
ctx.strokeStyle=npc.shirt; ctx.lineWidth=2;
roundRect(ctx,10,300,620,170,10); ctx.stroke();
// portrait
ctx.fillStyle=npc.shirt;
ctx.beginPath(); ctx.arc(55,340,28,0,Math.PI2); ctx.fill();
ctx.fillStyle='#FDBCB4';
ctx.beginPath(); ctx.arc(55,333,12,0,Math.PI2); ctx.fill();
ctx.fillStyle=npc.hair;
ctx.beginPath(); ctx.arc(55,328,11,Math.PI,0); ctx.fill();
// question number
ctx.fillStyle=npc.shirt;
ctx.font='bold 13px sans-serif';
ctx.fillText(${npc.name} – Question ${quizIndex+1}/3, 95, 320);
// question text
ctx.fillStyle='white'; ctx.font='bold 16px sans-serif';
ctx.fillText(q.q, 95, 345);
// grammar tip mini
ctx.fillStyle='#87CEEB'; ctx.font='12px sans-serif';
ctx.fillText('💡 '+npc.grammarTip.split('\n')[0], 95, 365);
if (quizResult === null) {
// answer buttons
q.opts.forEach((opt,i) => {
const b = qBtns[i];
const hov = hoveredBtn===i;
ctx.fillStyle = hov ? '#2980B9' : '#1a3a5c';
roundRect(ctx,b.x,b.y,b.w,b.h,8); ctx.fill();
ctx.strokeStyle = hov ? '#5DADE2' : '#2E86AB';
ctx.lineWidth=2;
roundRect(ctx,b.x,b.y,b.w,b.h,8); ctx.stroke();
ctx.fillStyle='white'; ctx.font='bold 15px sans-serif';
ctx.textAlign='center';
ctx.fillText(opt, b.x+b.w/2, b.y+24);
ctx.textAlign='left';
});
} else {
// feedback
const correct = quizResult==='correct';
ctx.fillStyle = correct ? 'rgba(46,204,113,0.3)' : 'rgba(231,76,60,0.3)';
roundRect(ctx,60,385,520,60,8); ctx.fill();
ctx.fillStyle = correct ? '#2ECC71' : '#E74C3C';
ctx.font='bold 18px sans-serif';
ctx.textAlign='center';
ctx.fillText(correct ? '✅ Correct! Well done!' : '❌ Not quite...', 320, 410);
ctx.fillStyle='white'; ctx.font='14px sans-serif';
ctx.fillText('💡 '+quizExp, 320, 432);
ctx.fillStyle='#87CEEB'; ctx.font='12px sans-serif';
ctx.fillText('Click to continue', 320, 455);
ctx.textAlign='left';
}
}
// ── DRAWING: MENU ─────────────────────────────────────────────
function drawMenu() {
// sky
const skyGrad = ctx.createLinearGradient(0,0,0,480);
skyGrad.addColorStop(0,'#87CEEB');
skyGrad.addColorStop(0.6,'#B0E0FF');
skyGrad.addColorStop(1,'#F4D03F');
ctx.fillStyle=skyGrad; ctx.fillRect(0,0,640,480);
// ocean
ctx.fillStyle='#2E86AB';
ctx.fillRect(0,300,640,180);
ctx.fillStyle='rgba(255,255,255,0.3)';
for(let i=0;i<5;i++) ctx.fillRect(i130+((frame0.5)%130),310,80,4);
// clouds
drawDecorations();
// title box
ctx.fillStyle='rgba(0,0,0,0.45)';
roundRect(ctx,80,60,480,100,16); ctx.fill();
ctx.fillStyle='#FFE066';
ctx.font='bold 46px sans-serif';
ctx.textAlign='center';
ctx.shadowColor='#000'; ctx.shadowBlur=8;
ctx.fillText("Silky's Adventures", 320, 120);
ctx.shadowBlur=0;
ctx.fillStyle='white'; ctx.font='18px sans-serif';
ctx.fillText('An English Adventure in Plymouth! 🏖️', 320, 148);
// animated Silky on menu
const menuSilkyY = 230 + Math.sin(frame*0.06)*6;
drawSilky(320, menuSilkyY);
// start prompt
if (Math.floor(frame/35)%2===0) {
ctx.fillStyle='white'; ctx.font='bold 18px sans-serif';
ctx.fillText('Press ENTER or click to Start', 320, 310);
}
ctx.fillStyle='rgba(255,255,255,0.6)'; ctx.font='13px sans-serif';
ctx.fillText('Klasse 6 Gymnasium · A1 Level · Plymouth, England', 320, 460);
ctx.textAlign='left';
}
// ── DRAWING: WIN ──────────────────────────────────────────────
function drawWin() {
ctx.fillStyle='rgba(0,20,60,0.95)';
ctx.fillRect(0,0,640,480);
ctx.textAlign='center';
ctx.fillStyle='#FFE066'; ctx.font='bold 40px sans-serif';
ctx.fillText('🌟 Well done, Silky! 🌟', 320, 120);
ctx.fillStyle='white'; ctx.font='22px sans-serif';
ctx.fillText('You completed Plymouth Beach!', 320, 170);
ctx.fillStyle='#FFE066'; ctx.font='bold 30px sans-serif';
ctx.fillText('⭐ Stars collected: '+player.stars, 320, 230);
ctx.fillStyle='#87CEEB'; ctx.font='16px sans-serif';
ctx.fillText('You practised:', 320, 280);
const topics = ['✅ To Be (am/is/are)','✅ Simple Present (-s/-es)','✅ Have / Has','✅ There is / There are','✅ Present Progressive (-ing)'];
topics.forEach((t,i) => {
ctx.fillStyle='#2ECC71'; ctx.font='15px sans-serif';
ctx.fillText(t, 320, 305+i*24);
});
if (Math.floor(frame/35)%2===0) {
ctx.fillStyle='white'; ctx.font='bold 16px sans-serif';
ctx.fillText('Click to play again', 320, 460);
}
ctx.textAlign='left';
}
// ── GAME LOGIC ────────────────────────────────────────────────
function startGame() {
state = STATE.PLAYING;
}
function resetGame() {
player.x=10TILE_SIZE+16; player.y=7TILE_SIZE+16;
player.stars=0; player.hearts=3;
npcs.forEach(n=>n.done=false);
localStorage.setItem('silkyStars','0');
state=STATE.MENU;
}
function tryTalkToNPC() {
for (const npc of npcs) {
if (npc.done) continue;
const dist = Math.hypot(player.x-npc.x, player.y-npc.y);
if (dist < 52) {
activeNPC = npc;
dlgPhase = 0;
dlgPage = 0;
quizIndex = 0;
quizResult= null;
quizEarned= 0;
state = STATE.DIALOGUE;
return;
}
}
}
function advanceDialogue() {
if (dlgPhase===0) { dlgPhase=1; }
else if (dlgPhase===1) {
dlgPhase=2;
quizIndex=0; quizResult=null;
state=STATE.QUIZ;
}
}
function selectAnswer(i) {
if (!activeNPC||quizResult!==null) return;
const q = activeNPC.questions[quizIndex];
if (i===q.ans) {
quizResult='correct';
player.stars+=10;
quizEarned+=10;
localStorage.setItem('silkyStars',player.stars);
} else {
quizResult='wrong';
}
quizExp = q.exp;
quizFlash=20;
}
function nextQuizStep() {
quizResult=null;
quizIndex++;
if (quizIndex>=activeNPC.questions.length) {
// quiz done
activeNPC.done=true;
const allDone = npcs.every(n=>n.done);
activeNPC=null;
state = allDone ? STATE.WIN : STATE.PLAYING;
}
}
// ── MAIN LOOP ─────────────────────────────────────────────────
function update() {
frame++;
waterPulse += 0.04;
lighthouseAngle += 0.012;
seagulls.forEach(sg => { sg.x+=sg.spd; if(sg.x>660) sg.x=-20; });
clouds.forEach(cl => { cl.x+=cl.spd; if(cl.x>700) cl.x=-120; });
if (state===STATE.PLAYING) {
movePlayer();
updateCamera(player.x, player.y);
if (justPressedE) tryTalkToNPC();
}
if (state===STATE.DIALOGUE && justPressedE) advanceDialogue();
if (state===STATE.QUIZ && justPressedE && quizResult!==null) nextQuizStep();
if (state===STATE.MENU && justPressedEnter) startGame();
justPressedE=false; justPressedEnter=false;
}
function draw() {
ctx.clearRect(0,0,640,480);
if (state===STATE.MENU) { drawMenu(); return; }
if (state===STATE.WIN) { drawWin(); return; }
// sky background
const skyGrad = ctx.createLinearGradient(0,0,0,480);
skyGrad.addColorStop(0,'#87CEEB');
skyGrad.addColorStop(0.4,'#B0E0FF');
skyGrad.addColorStop(1,'#F4D03F');
ctx.fillStyle=skyGrad; ctx.fillRect(0,0,640,480);
drawDecorations();
drawMap();
drawLighthouse();
// draw NPCs
npcs.forEach(drawNPC);
// draw player
const sx = player.x - cam.x;
const sy = player.y - cam.y;
drawSilky(sx, sy);
drawHUD();
if (state===STATE.DIALOGUE) drawDialogueBox();
if (state===STATE.QUIZ) drawQuiz();
// quiz flash overlay
if (quizFlash>0) {
const col = quizResult==='correct' ? 'rgba(46,204,113,' : 'rgba(231,76,60,';
ctx.fillStyle=col+(quizFlash/20*0.3)+')';
ctx.fillRect(0,0,640,480);
quizFlash--;
}
}
function loop() {
update();
draw();
requestAnimationFrame(loop);
}
loop();
</script>
