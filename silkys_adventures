shirt:'#27AE60', hair:'#4A0080', done:false,
greeting:"💃 I am dancing right now!\nCan you use -ING forms too?\nLet's move and learn! 🕺",
grammarTip:"Present Progressive:\nam / is / are + verb-ING.\nShows what is happening NOW.",
questions:[
{q:"Silky ___ on the beach. (play)", opts:["is playing","is plays","are playing"], ans:0, exp:"Silky (she) → IS PLAYING"},
