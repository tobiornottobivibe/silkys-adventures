ctx.fillStyle='#2C1810';
ctx.beginPath(); ctx.ellipse(x+eyeOff,y-6,3,2,0,0,Math.PI*2); ctx.fill();
// whiskers
ctx.strokeStyle='rgba(255,255,255,0.8)'; ctx.lineWidth=1;
[-1,1].forEach(side => {
for(let i=0;i<3;i++) {
ctx.beginPath();
ctx.moveTo(x+eyeOff, y-6+i2);
ctx.lineTo(x+eyeOff+side14, y-7+i*2);
ctx.stroke();
}
});
}
// ── DRAWING: NPC ──────────────────────────────────────────────
function drawNPC(npc) {
const sx = npc.x - cam.x;
