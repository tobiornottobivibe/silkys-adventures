ctx.beginPath(); ctx.arc(x,y-8,11,0,Math.PI2); ctx.fill();
ctx.fillStyle='#4A90D9';
ctx.beginPath(); ctx.arc(x,y-9,8,0,Math.PI2); ctx.fill();
// eyes
